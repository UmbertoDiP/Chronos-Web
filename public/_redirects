# Chronos - SPA Routing for Cloudflare Pages
# Ensures all routes are crawlable by search engines

# Static assets (serve directly)
/sitemap.xml          /sitemap.xml          200
/robots.txt           /robots.txt           200
/favicon.ico          /favicon.ico          200
/favicon.png          /favicon.png          200
/og-image.png         /og-image.png         200
/apple-touch-icon.png /apple-touch-icon.png 200
/manifest.json        /manifest.json        200
/remote_policy.json   /remote_policy.json   200

# SPA routes (serve index.html with 200 status for proper crawling)
/privacy              /index.html           200
/terms                /index.html           200
/it                   /index.html           200
/it/privacy           /index.html           200
/it/terms             /index.html           200
/es                   /index.html           200
/fr                   /index.html           200
/de                   /index.html           200

# Catch-all SPA fallback (must be last)
/*                    /index.html           200

name = "folder2text"
compatibility_date = "2024-01-01"
pages_build_output_dir = "dist"

[env.production]
name = "folder2text"
route = { pattern = "folder2text.com/*", zone_name = "folder2text.com" }

[[env.production.routes]]
pattern = "folder2text.com/*"
zone_name = "folder2text.com"

[[env.production.routes]]
pattern = "www.folder2text.com/*"
zone_name = "folder2text.com"
